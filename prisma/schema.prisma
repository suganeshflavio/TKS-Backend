// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db` output   = "../src/generated/prisma" role         String   @default("student")

generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
}

model User {
  id           String   @id @default(cuid())

  name         String

  email        String   @unique

  mobile        String?

  password     String

  role          Role     @default(STUDENT)

  deviceId     String?

  sessionToken String?

  isActive      Boolean  @default(true)

  createdAt    DateTime @default(now())

  updatedAt    DateTime @updatedAt
}
